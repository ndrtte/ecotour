---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { actividades, siteData, fullSchedule } from '../data/siteData';
---

<Layout title={`Classes - ${siteData.name}`} description="Browse our wide range of fitness classes">
  <!-- Hero Section -->
  <section class="pt-32 pb-20 bg-linear-to-br from-slate-900 via-slate-800 to-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">Nuestras Excursiones</h1>
        <p class="text-xl text-gray-300">
          Encuentra la aventura perfecta según tu nivel y lo que buscas vivir
        </p>
      </div>
    </div>
  </section>

  <!-- Detailed Classes Section -->
  <section class="py-20 bg-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-16">
        {actividades.map((actividad) => (
          <div class="bg-slate-900 rounded-xl border border-slate-700 overflow-hidden">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
              <!-- Image -->
              <div class="relative h-64 lg:h-auto">
                {actividad.imagen && (
                  <Image
                    src={actividad.imagen}
                    alt={actividad.nombre}
                    width={800}
                    height={600}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                )}
                <div class="absolute top-4 right-4">
                  <span class="bg-orange-500 text-white text-sm px-4 py-2 rounded-full font-semibold">
                    {actividad.dificultad}
                  </span>
                </div>
              </div>
              
              <!-- Content -->
              <div class="p-8">
                <div class="flex items-center justify-between mb-4">
                  <h2 class="text-3xl font-bold text-white">{actividad.nombre}</h2>
                  <div class="flex items-center text-gray-400 gap-2">
                    <i class="ri-price-tag-3-line text-orange-500"></i>
                    <span>{actividad.precio}</span>
                  </div>
                </div>
                
                <p class="text-gray-300 text-lg mb-4 leading-relaxed">{actividad.descripcionDetallada}</p>
                
                <div class="mb-6">
                  <p class="text-gray-400 text-sm">Que puedes esperar: {actividad.queEsperar}</p>
                </div>
                
                <div class="mb-6">
                  <h4 class="text-white font-semibold mb-3">Detalles:</h4>
                  <ul class="grid grid-cols-2 gap-2">
                    {actividad.detalles.map((detalle) => (
                      <li class="flex items-center gap-2 text-gray-300 text-sm">
                        <i class="ri-checkbox-circle-fill text-orange-500"></i>
                        {detalle}
                      </li>
                    ))}
                  </ul>
                </div>
                
                <a
                  href="/contact"
                  class="inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white px-6 py-3 rounded-lg font-semibold transition-all"
                >
                  Contáctanos para más información
                  <i class="ri-arrow-right-line"></i>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

