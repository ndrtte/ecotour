---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { siteData, lineamientos } from "../data/siteData";
---

<Layout
  title={`About Us - ${siteData.name}`}
  description="Learn about our mission, values, and expert trainers"
>
  <!-- Hero Section -->
  <section
    class="pt-32 pb-20 bg-linear-to-br from-slate-900 via-slate-800 to-slate-900"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">
          Requisitos de admisión y seguridad
        </h1>
        <p class="text-xl text-gray-300">
          Antes de cada experiencia, todos los participantes deben cumplir con
          los siguientes requisitos. Están diseñados para garantizar tu
          seguridad y la de quienes te acompañan.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="relative">
          <div
            class="absolute left-8 top-0 bottom-0 w-0.5 bg-orange-500/30 hidden md:block"
          >
          </div>

          <div class="space-y-12">
            {
              lineamientos.map((lineamiento, index) => (
                <div class="relative flex items-start gap-6">
                  <div class="hidden md:block shrink-0">
                    <div class="w-16 h-16 bg-orange-500 rounded-full flex items-center justify-center border-4 border-slate-900">
                      <span class="text-white font-bold text-sm">
                        {lineamiento.numero}
                      </span>
                    </div>
                  </div>
                  <div class="flex-1 bg-slate-800 p-6 rounded-xl border border-slate-700 hover:border-orange-500 transition-all">
                    <div class="md:hidden mb-2">
                      <span class="bg-orange-500 text-white px-3 py-1 rounded-full text-sm font-bold">
                        {lineamiento.numero}
                      </span>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">
                      {lineamiento.titulo}
                    </h3>
                    <p class="text-gray-300 leading-relaxed">
                      {lineamiento.descripcion}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
