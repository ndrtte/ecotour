---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
import { siteData, socialLinks, contactInfo } from "../data/siteData";
import MapImage from "@assets/photo-1517487881594-2787fef5ebf7.jpg";
---

<Layout
  title={`Contact Us - ${siteData.name}`}
  description="Contáctanos para vivir tu próxima experiencia con nosotros."
>
  <!-- Hero Section -->
  <section
    class="pt-32 pb-20 bg-linear-to-br from-slate-900 via-slate-800 to-slate-900"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">
          Contáctanos
        </h1>
        <p class="text-xl text-gray-300">
          ¿Tienes dudas o quieres reservar tu experiencia? Estamos aquí para
          ayudarte a planificar tu visita y darte la mejor atención.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Info & Form -->
  <section class="py-20 bg-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
        <!-- Contact Information -->
        <div>
          <h2 class="text-3xl font-bold text-white mb-8">Contáctanos</h2>
          <div class="space-y-6">
            {
              contactInfo.map((info) => (
                <div class="flex items-start gap-4">
                  <div class="bg-orange-500 p-4 rounded-lg shrink-0">
                    <i class={`${info.icon} text-2xl text-white`} />
                  </div>
                  <div>
                    <h3 class="text-xl font-semibold text-white mb-2">
                      {info.title}
                    </h3>
                    {Array.isArray(info.content) ? (
                      info.content.map((line) => (
                        <p class="text-gray-400 leading-relaxed">{line}</p>
                      ))
                    ) : info.link ? (
                      <a
                        href={info.link}
                        class="text-gray-400 hover:text-orange-500 transition-colors"
                      >
                        {info.content}
                      </a>
                    ) : (
                      <p class="text-gray-400 leading-relaxed">
                        {info.content}
                      </p>
                    )}
                  </div>
                </div>
              ))
            }
          </div>

          <!-- Social Links -->
          <div class="mt-10">
            <h3 class="text-xl font-semibold text-white mb-4">Siguenos</h3>
            <div class="flex space-x-4">
              {
                socialLinks.map((social) => (
                  <a
                    href={
                      siteData.social[
                        social.name as keyof typeof siteData.social
                      ]
                    }
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-12 h-12 bg-slate-700 hover:bg-orange-500 rounded-lg flex items-center justify-center transition-all"
                    aria-label={social.label}
                  >
                    <i class={`${social.icon} text-xl text-white`} />
                  </a>
                ))
              }
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <!-- Response Time Section -->
  <section class="py-20 bg-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="bg-slate-900 p-8 rounded-xl border border-slate-700">
          <div class="flex items-start gap-6">
            <div class="bg-orange-500/10 p-4 rounded-lg shrink-0">
              <i class="ri-time-line text-4xl text-orange-500"></i>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-white mb-3">Tiempo de respuesta:</h3>
              <p class="text-gray-300 mb-4 leading-relaxed">
                Nos comprometemos a responderte lo más rápido posible. Esto es
                lo que puedes esperar de nuestro equipo:
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <i
                    class="ri-checkbox-circle-fill text-orange-500 text-xl mt-0.5"
                  ></i>
                  <div>
                    <span class="text-white font-semibold"
                      >Consultas por correo:</span
                    >
                    <span class="text-gray-300">
                      Respondemos en menos de 24 horas en días hábiles
                    </span>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <i
                    class="ri-checkbox-circle-fill text-orange-500 text-xl mt-0.5"
                  ></i>
                  <div>
                    <span class="text-white font-semibold"
                      >Llamadas telefónicas:</span
                    >
                    <span class="text-gray-300">
                      Disponibles durante horario de atención (5:00 AM - 11:00
                      PM)
                    </span>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <i
                    class="ri-checkbox-circle-fill text-orange-500 text-xl mt-0.5"
                  ></i>
                  <div>
                    <span class="text-white font-semibold"
                      >Envío de formulario:</span
                    >
                    <span class="text-gray-300">
                      Confirmación en menos de 2 horas y respuesta completa en
                      un máximo de 24 horas
                    </span>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <i
                    class="ri-checkbox-circle-fill text-orange-500 text-xl mt-0.5"
                  ></i>
                  <div>
                    <span class="text-white font-semibold"
                      >Asuntos urgentes:</span
                    >
                    <span class="text-gray-300">
                      Llámanos directamente para atención inmediata
                    </span>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
