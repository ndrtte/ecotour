---
import { Image } from "astro:assets";
import { siteData, equipo } from "../data/siteData";
---

<!-- Hero Section -->
<section
  class="pt-32 pb-20 bg-linear-to-br from-slate-900 via-slate-800 to-slate-900"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto">
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">
        Sobre {siteData.name}
      </h1>
      <p class="text-xl text-gray-300">
        Creamos experiencias al aire libre diseñadas para que disfrutes,
        explores y vivas momentos inolvidables.
      </p>
    </div>
  </div>
</section>

<!-- Mission Section -->
<section class="py-20 bg-slate-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold text-white mb-8 text-center">
        Nuestra Misión
      </h2>
      <div class="prose prose-invert max-w-none">
        <p class="text-xl text-gray-300 mb-6">
          En {siteData.name} creemos que las mejores experiencias nacen del contacto
          con la naturaleza, la aventura y los momentos compartidos. Nuestra misión
          es ofrecer actividades accesibles y memorables para personas y familias
          que buscan algo diferente.
        </p>
        <p class="text-lg text-gray-400 mb-6">
          Brindamos espacios cuidados, experiencias guiadas y un entorno seguro
          que permite a cada visitante disfrutar, desconectarse y vivir el lugar
          a su propio ritmo.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Values Section -->
<section class="py-20 bg-slate-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-4xl font-bold text-white mb-12 text-center">
      Nuestros Valores
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      <div
        class="bg-slate-800 p-8 rounded-xl border border-slate-700 text-center hover:border-orange-500 transition-all"
      >
        <div
          class="w-20 h-20 bg-orange-500/10 rounded-lg flex items-center justify-center mx-auto mb-6"
        >
          <i class="ri-trophy-line text-4xl text-orange-500"></i>
        </div>
        <h3 class="text-2xl font-bold text-white mb-3">
          Calidad en la experiencia
        </h3>
        <p class="text-gray-400 leading-relaxed">
          Nos enfocamos en ofrecer experiencias bien cuidadas, seguras y
          memorables en cada visita.
        </p>
      </div>
      <div
        class="bg-slate-800 p-8 rounded-xl border border-slate-700 text-center hover:border-orange-500 transition-all"
      >
        <div
          class="w-20 h-20 bg-orange-500/10 rounded-lg flex items-center justify-center mx-auto mb-6"
        >
          <i class="ri-hand-heart-line text-4xl text-orange-500"></i>
        </div>
        <h3 class="text-2xl font-bold text-white mb-3">
          Experiencias compartidas
        </h3>
        <p class="text-gray-400 leading-relaxed">
          Creemos en experiencias que unen a las personas y se convierten en
          recuerdos inolvidables.
        </p>
      </div>
      <div
        class="bg-slate-800 p-8 rounded-xl border border-slate-700 text-center hover:border-orange-500 transition-all"
      >
        <div
          class="w-20 h-20 bg-orange-500/10 rounded-lg flex items-center justify-center mx-auto mb-6"
        >
          <i class="ri-focus-3-line text-4xl text-orange-500"></i>
        </div>
        <h3 class="text-2xl font-bold text-white mb-3">
          Momentos que importan
        </h3>
        <p class="text-gray-400 leading-relaxed">
          Buscamos que cada experiencia deje una huella positiva en quienes nos
          visitan.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Team Section -->
<section class="py-20 bg-slate-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-4xl font-bold text-white mb-4 text-center">
      Nuestro equipo
    </h2>
    <p class="text-xl text-gray-300 mb-12 text-center max-w-2xl mx-auto">
      Conoce a alguna de las personas que hacen posible cada experiencia, asegurando
      calidad, seguridad y atención en cada visita.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-4 lg:grid-cols-6 gap-8">
      {
        equipo.map((miembro, index) => {
          let className = "";
          if (index + 1 == 4) {
            className = "lg:col-start-2";
          } else if (index + 1 == 5) {
            className = "md:col-start-2 lg:col-start-4";
          }
          return (
            <div
              class={`bg-slate-900 p-8 rounded-xl border border-slate-700 hover:border-orange-500 transition-all transform hover:scale-105 md:col-span-2 ${className}`}
            >
              <div class="text-center mb-6">
                <div class="w-40 h-40 rounded-full mx-auto mb-4 overflow-hidden border-4 border-orange-500/20">
                  <Image
                    src={miembro.image}
                    alt={`${miembro.name} - ${miembro.role}`}
                    width={400}
                    height={400}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
                <h3 class="text-xl font-bold text-white mb-2">
                  {miembro.name}
                </h3>
                <p class="text-orange-500 mb-1 font-semibold">{miembro.role}</p>
                <p class="text-gray-400 text-sm mb-3">
                  {miembro.specialization}
                </p>
                <p class="text-gray-500 text-xs">
                  {miembro.experience} experience
                </p>
              </div>
              <p class="text-gray-300 text-sm leading-relaxed mb-4 text-center">
                {miembro.bio}
              </p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
